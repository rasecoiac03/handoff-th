datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CONTRACTOR
  HOMEOWNER
}

enum JobStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  password      String
  role          Role
  createdAt     DateTime      @default(now())
  jobs          Job[]         @relation("ContractorJobs")
  homeownerJobs Job[]         @relation("JobHomeowners")
  chats         Chat[]        @relation("ChatParticipants")
  messages      Message[]
  revisions     JobRevision[]
}

model Job {
  id             String        @id @default(uuid())
  description    String
  location       String
  status         JobStatus     @default(PLANNING)
  cost           Float?
  contractorId   String
  contractor     User          @relation("ContractorJobs", fields: [contractorId], references: [id])
  homeowners     User[]        @relation("JobHomeowners")
  chats          Chat[]
  currentVersion Int           @default(1)
  headVersion    Int           @default(1)
  revisions      JobRevision[]
  subtasks       SubTask[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model SubTask {
  id          String    @id @default(uuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  description String
  deadline    DateTime?
  cost        Float?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([jobId, position])
}

model JobRevision {
  id          String   @id @default(uuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id])
  createdAt   DateTime @default(now())

  @@unique([jobId, version])
}

model Chat {
  id           String    @id @default(uuid())
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id])
  participants User[]    @relation("ChatParticipants")
  messages     Message[]
  createdAt    DateTime  @default(now())
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())
}
